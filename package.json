{
  "name": "@lvce-editor/extension-detail-view-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:static": "node packages/build/src/build-static.js",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/extension-detail-view-worker/src/extensionDetailViewWorkerMain.ts --outfile=.tmp/dist/dist/extensionDetailViewWorkerMain.js",
    "dev": "node packages/build/src/dev.js",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:firefox": "cd packages/e2e && npm run e2e:firefox",
    "e2e:firefox:headless": "cd packages/e2e && npm run e2e:firefox:headless",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "measure": "cd packages/memory && npm run measure",
    "test": "lerna run test",
    "test-integration": "lerna run test-integration",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^16.2.0",
    "@lvce-editor/eslint-plugin-github-actions": "^10.2.0",
    "eslint": "^10.6.0",
    "knip": "^6.20.0",
    "lerna": "^8.2.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
